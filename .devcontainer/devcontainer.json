{
	"name": "work4all n8n integration",
	"image": "mcr.microsoft.com/devcontainers/javascript-node:24-bookworm",
	"features": {
		"ghcr.io/devcontainers/features/git:1": {}
	},
	"mounts": [
		"source=work4all-n8n-dev,target=/home/node/.n8n-node-cli,type=volume",
		"source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind,consistency=cached"
	],
	"forwardPorts": [
		5678
	],
	"portsAttributes": {
		"5678": {
			"label": "n8n (npm run dev)",
			"onAutoForward": "notify"
		}
	},
	"postCreateCommand": "sudo chown -R node:node /home/node/.n8n-node-cli 2>/dev/null || true && npm ci && npm run build",
	"customizations": {
		"vscode": {
			"extensions": [
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode",
				"EditorConfig.EditorConfig",
				"anthropic.claude-code"
			],
			"settings": {
				"editor.formatOnSave": true,
				"editor.defaultFormatter": "esbenp.prettier-vscode",
				"eslint.useFlatConfig": true,
				"claudeCode.allowDangerouslySkipPermissions": true,
				"claudeCode.initialPermissionMode": "bypassPermissions"
			}
		}
	},
	"remoteUser": "node"
}