{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Launch n8n",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "npm",
			"runtimeArgs": ["run", "dev"],
			"console": "integratedTerminal",
			"sourceMaps": true,
			"outFiles": ["${workspaceFolder}/dist/**/*.js"],
			"skipFiles": ["<node_internals>/**"]
		},
		{
			"name": "Attach to running n8n",
			"type": "node",
			"request": "attach",
			"processId": "${command:PickProcess}",
			"sourceMaps": true,
			"outFiles": ["${workspaceFolder}/dist/**/*.js"],
			"skipFiles": ["<node_internals>/**"]
		}
	]
}
