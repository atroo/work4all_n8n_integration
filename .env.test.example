# Copy this file to .env.test and fill in your values.
# .env.test is gitignored — never commit real credentials.

# Base URL of the work4all API instance to test against
W4A_BASE_URL=https://api.work4all.de

W4A_API_CLIENT_ID=**********
W4A_API_CLIENT_SECRET=**********
W4A_API_ACCESS_TOKEN_URL=**********

# Internal work4all supplier code that must exist in your tenant
W4A_TEST_SUPPLIER_CODE=12345

# Sachkonto code used for the invoice line items in tests
W4A_TEST_ACCOUNT_CODE=6000
